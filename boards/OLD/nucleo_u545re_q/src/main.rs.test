#[no_mangle]
pub unsafe fn main() {
    // 1. Enable Clocks (GPIOA on AHB2)
    let rcc_ahb2enr = 0x46020C8C as *mut u32;
    *rcc_ahb2enr |= 0x00000001; 

    // 2. Configure PA5 as Output (LED)
    let gpioa_moder = 0x42020000 as *mut u32;
    *gpioa_moder &= !(0x3 << (5 * 2)); // Clear mode for PA5
    *gpioa_moder |= (0x1 << (5 * 2));  // Set mode to Output for PA5

    let gpioa_odr = 0x42020014 as *mut u32;

    loop {
        *gpioa_odr ^= (1 << 5); // Toggle PA5
        for _ in 0..1_000_000 {
            cortexm33::support::nop();
        }
    }
}
