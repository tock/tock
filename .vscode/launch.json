{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "nRF52-DK",
            "type": "gdb",
            "request": "attach",
            "executable": "${workspaceRoot}/boards/nrf52dk/target/thumbv7em-none-eabi/release/nrf52dk",
            "target": "localhost:2331",
            "remote": true,
            "cwd": "${workspaceRoot}",
            "gdbpath": "arm-none-eabi-gdb",
            "autorun": [
                "monitor reset",
                "monitor speed auto",
                "b initialize_ram_jump_to_main"
            ]
        },
        {
            "name": "MSP432 Cortex Debug",
            "type": "cortex-debug",
            "servertype": "openocd",
            "request": "launch",
            "executable": "${workspaceRoot}/target/thumbv7em-none-eabi/debug/msp-exp432p401r.elf",
            "cwd": "${workspaceRoot}",
            "svdFile": "${workspaceRoot}/boards/msp_exp432p401r/msp432.svd",
            "runToMain": true,
            "configFiles": [
                "${workspaceRoot}/boards/msp_exp432p401r/openocd.cfg",
            ]
        },
        {
            "showDevDebugOutput": "none",
            "name": "M33-qemu",
            "loadFiles": [], // disable loading of binary. .bin is not supported by gdb so we load .bin with qemu
            "type": "cortex-debug",
            "request": "launch",
            "executable": "",
            "symbolFiles": [
                {
                    "file": "target/thumbv8m.main-none-eabi/debug/musca_b1_board"
                }
            ],
            "svdFile": "../Musca_B1.svd", // optional .svd file for peripheral register view
            "servertype": "external",
            "cwd": "${workspaceFolder}",
            "gdbTarget": "localhost:1234",
            "gdbPath": "arm-none-eabi-gdb",
            "objdumpPath": "arm-none-eabi-objdump",
            "preLaunchCommands": [
                // somehow gdb/qemu doesn't set the stack pointer correctly. only needed for elf debugging.
                // "set $sp = 0x30003000"
            ],
        }
    ]
}
