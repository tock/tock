{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "nRF52-DK",
            "type": "gdb",
            "request": "attach",
            "executable": "${workspaceRoot}/boards/nrf52dk/target/thumbv7em-none-eabi/release/nrf52dk",
            "target": "localhost:2331",
            "remote": true,
            "cwd": "${workspaceRoot}",
            "gdbpath": "arm-none-eabi-gdb",
            "autorun": [
                "monitor reset",
                "monitor speed auto",
                "b initialize_ram_jump_to_main"
            ]
        },
        {
            "name": "MSP432 Cortex Debug",
            "type": "cortex-debug",
            "servertype": "openocd",
            "request": "launch",
            "executable": "${workspaceRoot}/target/thumbv7em-none-eabi/debug/msp-exp432p401r.elf",
            "cwd": "${workspaceRoot}",
            "svdFile": "${workspaceRoot}/boards/msp_exp432p401r/msp432.svd",
            "runToMain": true,
            "configFiles": [
                "${workspaceRoot}/boards/msp_exp432p401r/openocd.cfg",
            ]
        },
        {
            "name": "PSC3 Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceRoot}/target/thumbv8m.main-none-eabi/debug/psc3m5_evk",
            "servertype": "openocd",
            "serverpath": "/opt/ModusToolboxProgtools-1.7/openocd/bin/openocd",
            "searchDir": [
                "/opt/ModusToolboxProgtools-1.7/",
            ],
            "openOCDPreConfigLaunchCommands": [
                "set DEBUG_CERTIFICATE ./packets/debug_token.bin"
            ],
            "configFiles": [
                "${workspaceRoot}/boards/psc3m5_evk/openocd.tcl"
            ],
            // "overrideLaunchCommands": [
            //     "set mem inaccessible-by-default off",
            //     "-enable-pretty-printing",
            //     "set remotetimeout 60",
            // ],
            "overrideRestartCommands": [
                "starti"
            ],
            // svdFile is optional, it can be very large.
            "svdFile": "../psc3.svd",
            "breakAfterReset": true,
            "runToEntryPoint": "main", // Specifies application entry point name where program will halt
            // "preLaunchTask": "Build", // Set this to run a task from tasks.json
            // before starting a debug session
            "showDevDebugOutput": "raw",
            "presentation": {
                "hidden": false,
                "group": "psc3m5_evk"
            },
            "liveWatch": {
                "enabled": true
            }
        },
    ]
}
